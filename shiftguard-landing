<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShiftGuard — Προστασία από Εργατικά Πρόστιμα</title>
<meta name="description" content="Αυτόματη παρακολούθηση βαρδιών για ξενοδοχεία. Ειδοποίηση WhatsApp σε πραγματικό χρόνο.">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --navy: #0a1628; --navy-mid: #1B2B6B; --navy-light: #243590;
  --red: #E8261A; --red-light: #ff4438; --cream: #f5f0e8;
  --white: #ffffff; --muted: #8899aa; --success: #4caf7d;
}
html { scroll-behavior: smooth; }
body { font-family: 'DM Sans', sans-serif; background: var(--navy); color: var(--white); overflow-x: hidden; }

/* ── NAV ── */
nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 18px 40px; display: flex; align-items: center; justify-content: space-between; background: rgba(10,22,40,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(232,38,26,0.1); }
.nav-logo { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--white); text-decoration: none; }
.nav-logo span { color: var(--red); }
.nav-links { display: flex; align-items: center; gap: 32px; }
.nav-links a { color: var(--muted); font-size: 14px; text-decoration: none; transition: color 0.2s; }
.nav-links a:hover { color: var(--white); }
.nav-cta { background: var(--red); color: var(--white) !important; padding: 9px 22px; border-radius: 8px; font-weight: 500; transition: background 0.2s !important; }
.nav-cta:hover { background: var(--red-light) !important; }

/* ── HERO ── */
.hero { min-height: 100vh; display: flex; align-items: center; padding: 120px 40px 80px; position: relative; overflow: hidden; }
.hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 70% 50%, rgba(27,43,107,0.4) 0%, transparent 70%), radial-gradient(ellipse 40% 40% at 20% 80%, rgba(232,38,26,0.08) 0%, transparent 60%); }
.hero-grid { position: absolute; inset: 0; opacity: 0.04; background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px; }
.hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; position: relative; z-index: 1; }
.hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(232,38,26,0.1); border: 1px solid rgba(232,38,26,0.3); border-radius: 20px; padding: 6px 16px; font-size: 12px; color: var(--red); letter-spacing: 0.5px; margin-bottom: 24px; animation: fadeUp 0.8s ease both; }
.hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(36px, 5vw, 58px); line-height: 1.1; color: var(--cream); margin-bottom: 24px; animation: fadeUp 0.8s ease 0.1s both; }
.hero h1 em { color: var(--red); font-style: normal; }
.hero-sub { font-size: 17px; color: var(--muted); line-height: 1.7; margin-bottom: 40px; animation: fadeUp 0.8s ease 0.2s both; }
.hero-actions { display: flex; gap: 16px; align-items: center; animation: fadeUp 0.8s ease 0.3s both; }
.btn-primary { background: var(--red); color: var(--white); padding: 14px 32px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; transition: all 0.2s; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; }
.btn-primary:hover { background: var(--red-light); transform: translateY(-2px); box-shadow: 0 12px 32px rgba(232,38,26,0.35); }
.btn-secondary { color: var(--muted); font-size: 14px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: color 0.2s; }
.btn-secondary:hover { color: var(--white); }

/* ── HERO MOCKUP ── */
.hero-visual { animation: fadeUp 0.8s ease 0.4s both; position: relative; }
.mockup-phone { background: #0d1f3c; border: 1.5px solid rgba(232,38,26,0.2); border-radius: 24px; padding: 20px; max-width: 320px; margin: 0 auto; box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05); }
.mp-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; padding-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.06); }
.mp-logo { font-family: 'DM Serif Display', serif; font-size: 16px; color: var(--white); }
.mp-logo span { color: var(--red); }
.mp-time { font-size: 13px; color: var(--red); font-family: 'DM Serif Display', serif; }
.mp-employee { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.03); border-radius: 12px; padding: 12px 14px; margin-bottom: 10px; border: 1px solid rgba(255,255,255,0.06); }
.mp-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, var(--navy-light), var(--red)); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; flex-shrink: 0; }
.mp-emp-info { flex: 1; }
.mp-emp-name { font-size: 13px; color: var(--cream); }
.mp-emp-shift { font-size: 11px; color: var(--muted); margin-top: 2px; }
.mp-status-ok { width: 26px; height: 26px; border-radius: 50%; background: rgba(76,175,125,0.15); border: 1px solid rgba(76,175,125,0.3); display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--success); }
.mp-status-miss { width: 26px; height: 26px; border-radius: 50%; background: rgba(232,38,26,0.15); border: 1px solid rgba(232,38,26,0.3); display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--red); }
.mp-employee.forgotten { animation: flashAlert 1s ease 2s both; }
@keyframes flashAlert { 0%{border-color:rgba(255,255,255,0.06)} 50%{border-color:rgba(232,38,26,0.6);background:rgba(232,38,26,0.08)} 100%{border-color:rgba(232,38,26,0.3);background:rgba(232,38,26,0.05)} }
.wa-bubble { position: absolute; right: -30px; bottom: 40px; background: #111827; border-radius: 16px; padding: 12px 14px; width: 260px; box-shadow: 0 20px 50px rgba(0,0,0,0.6); border: 1px solid rgba(255,255,255,0.08); opacity: 0; transform: translateY(20px) scale(0.95); animation: popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) 3.2s both; }
@keyframes popIn { to { opacity: 1; transform: translateY(0) scale(1); } }
.wa-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.wa-icon { width: 28px; height: 28px; background: #25D366; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
.wa-from { font-size: 12px; font-weight: 600; color: var(--white); }
.wa-time { margin-left: auto; font-size: 10px; color: rgba(255,255,255,0.35); }
.wa-msg { font-size: 11px; color: rgba(255,255,255,0.7); line-height: 1.5; background: rgba(255,255,255,0.04); border-radius: 8px; padding: 8px 10px; }
.wa-msg strong { color: var(--red); }
.wa-dot { position: absolute; top: -4px; right: -4px; width: 12px; height: 12px; border-radius: 50%; background: var(--red); opacity: 0; animation: dotPulse 1.5s ease-in-out 3.2s infinite; }
@keyframes dotPulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.3)} }
.mp-clock-tick { animation: tickRed 1s ease 1.5s both; }
@keyframes tickRed { 0%{color:var(--red)} 50%{color:#ff6b6b;transform:scale(1.05)} 100%{color:var(--red)} }

/* ── STATS BAR ── */
.stats-bar { background: rgba(255,255,255,0.02); border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 32px 40px; }
.stats-bar-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
.stat-item { text-align: center; padding: 0 20px; }
.stat-item:not(:last-child) { border-right: 1px solid rgba(255,255,255,0.06); }
.stat-num { font-family: 'DM Serif Display', serif; font-size: 42px; color: var(--red); }
.stat-desc { font-size: 13px; color: var(--muted); margin-top: 4px; }

/* ── SECTIONS ── */
section { padding: 100px 40px; }
.section-inner { max-width: 1200px; margin: 0 auto; }
.section-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
.section-title { font-family: 'DM Serif Display', serif; font-size: clamp(28px, 4vw, 44px); color: var(--cream); margin-bottom: 16px; line-height: 1.2; }
.section-sub { font-size: 16px; color: var(--muted); line-height: 1.7; max-width: 560px; }

/* ── HOW IT WORKS ── */
.how-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 60px; }
.how-card { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px; padding: 32px; position: relative; overflow: hidden; transition: border-color 0.3s, transform 0.3s; }
.how-card:hover { border-color: rgba(232,38,26,0.3); transform: translateY(-4px); }
.how-card::before { content: attr(data-num); position: absolute; top: -10px; right: 20px; font-family: 'DM Serif Display', serif; font-size: 80px; color: rgba(232,38,26,0.06); line-height: 1; }
.how-icon { font-size: 32px; margin-bottom: 20px; }
.how-title { font-family: 'DM Serif Display', serif; font-size: 20px; color: var(--cream); margin-bottom: 10px; }
.how-desc { font-size: 14px; color: var(--muted); line-height: 1.7; }

/* ── FEATURES ── */
.features-section { background: rgba(255,255,255,0.01); }
.features-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 60px; }
.feat-card { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 28px; display: flex; gap: 20px; align-items: flex-start; transition: border-color 0.3s; }
.feat-card:hover { border-color: rgba(232,38,26,0.25); }
.feat-icon-box { width: 44px; height: 44px; border-radius: 12px; background: rgba(232,38,26,0.1); border: 1px solid rgba(232,38,26,0.2); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
.feat-title { font-size: 15px; font-weight: 600; color: var(--cream); margin-bottom: 6px; }
.feat-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

/* ── PRICING ── */
.pricing-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 60px; max-width: 800px; }
.price-card { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 24px; padding: 36px; }
.price-card.featured { background: rgba(232,38,26,0.06); border-color: rgba(232,38,26,0.4); position: relative; }
.price-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--red); color: var(--white); font-size: 11px; font-weight: 600; padding: 4px 16px; border-radius: 20px; white-space: nowrap; }
.price-name { font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; }
.price-amount { font-family: 'DM Serif Display', serif; font-size: 48px; color: var(--cream); }
.price-amount span { font-size: 18px; color: var(--muted); }
.price-per { font-size: 13px; color: var(--muted); margin-bottom: 28px; }
.price-features { list-style: none; margin-bottom: 32px; }
.price-features li { font-size: 14px; color: var(--muted); padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.04); display: flex; align-items: center; gap: 10px; }
.price-features li::before { content: '✓'; color: var(--success); font-weight: 700; flex-shrink: 0; }
.price-features li.no::before { content: '×'; color: rgba(255,255,255,0.2); }
.price-features li.no { color: rgba(255,255,255,0.2); }
.btn-price { width: 100%; padding: 13px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; font-family: 'DM Sans', sans-serif; }
.btn-price-outline { background: transparent; border: 1px solid rgba(255,255,255,0.15) !important; color: var(--cream); }
.btn-price-outline:hover { border-color: rgba(232,38,26,0.5) !important; color: var(--red); }
.btn-price-solid { background: var(--red); color: var(--white); }
.btn-price-solid:hover { background: var(--red-light); }

/* ── CTA ── */
.cta-section { text-align: center; background: linear-gradient(135deg, rgba(27,43,107,0.3) 0%, rgba(232,38,26,0.08) 100%); border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); }
.cta-section .section-title { max-width: 600px; margin: 0 auto 16px; }
.cta-section .section-sub { margin: 0 auto 40px; text-align: center; }
.cta-form { display: flex; gap: 12px; max-width: 460px; margin: 0 auto; }
.cta-input { flex: 1; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 10px; padding: 13px 18px; color: var(--white); font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; transition: border-color 0.2s; }
.cta-input:focus { border-color: rgba(232,38,26,0.5); }
.cta-input::placeholder { color: var(--muted); }

/* ── FOOTER ── */
footer { padding: 40px; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); }
.footer-logo { font-family: 'DM Serif Display', serif; font-size: 20px; color: var(--white); margin-bottom: 8px; }
.footer-logo span { color: var(--red); }
.footer-tagline { font-size: 11px; color: rgba(136,153,170,0.5); margin-top: 4px; letter-spacing: 1px; text-transform: uppercase; }

/* ── ANIMATIONS ── */
@keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
.reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ── MOBILE ── */
@media (max-width: 768px) {
  nav { padding: 14px 20px; }
  .nav-links { display: none; }
  .hero { padding: 100px 20px 60px; }
  .hero-inner { grid-template-columns: 1fr; gap: 50px; }
  .wa-bubble { right: 0; bottom: -20px; width: 220px; }
  section { padding: 70px 20px; }
  .how-grid { grid-template-columns: 1fr; gap: 16px; }
  .features-grid { grid-template-columns: 1fr; }
  .pricing-grid { grid-template-columns: 1fr; max-width: 100%; }
  .stats-bar { padding: 32px 20px; }
  .stats-bar-inner { grid-template-columns: 1fr; gap: 24px; }
  .stat-item { border-right: none !important; border-bottom: 1px solid rgba(255,255,255,0.06); padding: 0 0 24px; }
  .stat-item:last-child { border-bottom: none; padding-bottom: 0; }
  .cta-form { flex-direction: column; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">Shift<span>Guard</span></a>
  <div class="nav-links">
    <a href="#how">Πώς λειτουργεί</a>
    <a href="#features">Χαρακτηριστικά</a>
    <a href="#pricing">Τιμές</a>
