  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-badge">🛡️ Για ξενοδοχεία & επιχειρήσεις</div>
      <h1>Μηδέν εργατικά<br>πρόστιμα από<br><em>ξεχασμένες βάρδιες</em></h1>
