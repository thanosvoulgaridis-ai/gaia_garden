<script>
function updateHeroClock() {
  const now = new Date();
  const t = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
  const el = document.getElementById('hero-clock');
  if (el) el.textContent = t;
}
updateHeroClock();
setInterval(updateHeroClock, 1000);

const observer = new IntersectionObserver(function(entries) {
  entries.forEach(function(entry) { if (entry.isIntersecting) entry.target.classList.add('visible'); });
}, { threshold: 0.15 });
document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el); });

function submitCTA() {
  const email = document.getElementById('cta-email').value.trim();
  if (!email || !email.includes('@')) { alert('Παρακαλώ εισάγετε έγκυρο email!'); return; }
  const btn = event.target;
  btn.textContent = '✅ Στάλθηκε!';
  btn.style.background = '#4caf7d';
  setTimeout(function() { btn.textContent = 'Ξεκινήστε →'; btn.style.background = ''; }, 3000);
}
</script>
