      <div class="stat-desc">Αυτόματος έλεγχος βαρδιών κάθε λεπτό</div>
    </div>
    <div class="stat-item reveal">
      <div class="stat-num">€0</div>
      <div class="stat-desc">Κόστος εγκατάστασης — λειτουργεί από tablet ή PC</div>
    </div>
  </div>
</div>

<!-- HOW IT WORKS -->
<section id="how">
