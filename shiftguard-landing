</section>

<!-- STATS -->
<div class="stats-bar">
  <div class="stats-bar-inner">
    <div class="stat-item reveal">
      <div class="stat-num">10'</div>
      <div class="stat-desc">Ειδοποίηση σε 10 λεπτά από αστοχία βάρδιας</div>
